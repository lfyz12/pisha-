SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
POSTGRES_DB=pisha_db
POSTGRES_USER=pisha
POSTGRES_PASSWORD=pisha_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost
# Default admin account created by `python manage.py seed_admin` or `seed_database`.
# Username: admin
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-admin-password
FIELD_ENCRYPTION_KEY=replace-with-a-fernet-key-from-cryptography.fernet.Fernet.generate_key

# --- AI assistant infrastructure ---
# Redis: Celery broker and result backend
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
# SurrealDB: vector/graph store for the AI assistant
SURREALDB_URL=ws://localhost:8000
SURREALDB_NS=pisha
SURREALDB_DB=pisha
SURREALDB_USER=root
SURREALDB_PASS=replace-with-a-strong-surrealdb-password
# LiteLLM gateway (chat, embeddings, rerank, classifier models)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=replace-with-a-litellm-api-key
LITELLM_CHAT_MODEL=gpt-4o-mini
LITELLM_EMBEDDING_MODEL=text-embedding-3-small
LITELLM_RERANK_MODEL=BAAI/bge-reranker-v2-m3
LITELLM_CLASSIFIER_MODEL=gpt-4o-mini
# Uploaded media files
MEDIA_ROOT=/app/media
# AI limits (read by Django settings)
AI_EMBEDDING_DIM=1536
AI_MAX_UPLOAD_MB=20
